### Sample GraphQL calls against the deployed mootmaker API.
### The API is authenticated by a Cognito user pool: every request must carry a JWT in the
### Authorization header. These samples use the acceptance-test app client's OAuth2
### client_credentials flow to obtain one - run the "Get an access token" request FIRST,
### then the other requests reference the token from its response.
###
### The variables below are read from the environment exported by authenticate.sh in the
### project root (`source authenticate.sh`).
### NOTE: REST Client's $processEnv reads the environment of the VSCode process itself, not your
### terminal - if VSCode was already running before you sourced authenticate.sh, either restart
### VSCode from that same shell, or launch `code .` from it so it inherits the exported variables.

@graphqlUrl = {{$processEnv GRAPHQL_API_URL}}
@tokenUrl = {{$processEnv COGNITO_TOKEN_URL}}
@clientId = {{$processEnv COGNITO_TEST_CLIENT_ID}}
@clientSecret = {{$processEnv COGNITO_TEST_CLIENT_SECRET}}
@scope = {{$processEnv COGNITO_TEST_SCOPE}}

### Get an access token (run FIRST; valid for 1 hour, re-run when it expires).
# @name cognitoToken
POST {{tokenUrl}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials&client_id={{clientId}}&client_secret={{clientSecret}}&scope={{scope}}

###
@accessToken = {{cognitoToken.response.body.$.access_token}}

### List rooms
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: {{accessToken}}

{
  "query": "query { rooms { id name capacity }  }"
}

### List people
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: {{accessToken}}

{
  "query": "query { people { id name } }"
}

### List meetings
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: {{accessToken}}

{
  "query": "query { meetings { id room { id name capacity } organiser { id name } attendees { id name } subject startTime endTime } }"
}

### Create a room
### On failure, "errors" is a non-empty list of the broken rules and "room" is null.
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: {{accessToken}}

{
  "query": "mutation CreateRoom($room: RoomInput!) { createRoom(room: $room) { room { id name capacity } errors } }",
  "variables": {
    "room": { "name": "Conference A", "capacity": 8 }
  }
}

### Create a person
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: {{accessToken}}

{
  "query": "mutation CreatePerson($person: PersonInput!) { createPerson(person: $person) { id name } }",
  "variables": {
    "person": { "name": "Geoff Weatherall" }
  }
}

### Create a meeting
### Replace roomId/organiserId/attendeeIds below with real ids from the "List rooms" / "List people" requests above.
### startTime/endTime must fall on a 5 minute boundary (e.g. :00, :05, :10, ...).
### On failure, "errors" is a non-empty list of the broken rules and "meeting" is null.
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: {{accessToken}}

{
  "query": "mutation CreateMeeting($meeting: MeetingInput!) { createMeeting(meeting: $meeting) { meeting { id room { id name capacity } organiser { id name } attendees { id name } subject startTime endTime } errors } }",
  "variables": {
    "meeting": {
      "roomId": "9fa8b122-9476-439f-ae5c-e97256444891",
      "organiserId": "4d4c933e-28c9-45ca-bf7c-a96f26cfa355",
      "attendeeIds": ["78514c8d-ac39-4a8a-9f97-abeb66eba37f"],
      "subject": "Weekly planning",
      "startTime": "2026-07-01T15:05:00",
      "endTime": "2026-07-01T15:10:00"
    }
  }
}

### Reset (deletes ALL stored rooms, people and meetings)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: {{accessToken}}

{
  "query": "mutation { reset }"
}

### Unauthenticated request - expect HTTP 401 UnauthorizedException (no Authorization header)
POST {{graphqlUrl}}
Content-Type: application/json

{
  "query": "query { rooms { id name capacity } }"
}
