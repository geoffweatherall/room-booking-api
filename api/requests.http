### Sample GraphQL calls against the deployed room-booking API.
### graphqlUrl/apiKey are read from the GRAPHQL_API_URL/GRAPHQL_API_KEY environment variables
### (see authenticate.sh in the project root: `source authenticate.sh`).
### NOTE: REST Client's $processEnv reads the environment of the VSCode process itself, not your
### terminal - if VSCode was already running before you sourced authenticate.sh, either restart
### VSCode from that same shell, or launch `code .` from it so it inherits the exported variables.

@graphqlUrl = {{$processEnv GRAPHQL_API_URL}}
@apiKey = {{$processEnv GRAPHQL_API_KEY}}

### List rooms
POST {{graphqlUrl}}
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "query": "query { rooms { id name capacity }  }"
}

### List people
POST {{graphqlUrl}}
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "query": "query { people { id name } }"
}

### List bookings
POST {{graphqlUrl}}
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "query": "query { bookings { id room { id name capacity } organiser { id name } attendees { id name } startTime endTime } }"
}

### Create a room
POST {{graphqlUrl}}
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "query": "mutation CreateRoom($room: RoomInput!) { createRoom(room: $room) { id name capacity } }",
  "variables": {
    "room": { "name": "Conference A", "capacity": 8 }
  }
}

### Create a person
POST {{graphqlUrl}}
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "query": "mutation CreatePerson($person: PersonInput!) { createPerson(person: $person) { id name } }",
  "variables": {
    "person": { "name": "Geoff Weatherall" }
  }
}

### Create a booking
### Replace roomId/organiserId/attendeeIds below with real ids from the "List rooms" / "List people" requests above.
### startTime/endTime must fall on a 5 minute boundary (e.g. :00, :05, :10, ...).
### On failure, "errors" is a non-empty list of the broken rules and "booking" is null.
POST {{graphqlUrl}}
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "query": "mutation CreateBooking($booking: BookingInput!) { createBooking(booking: $booking) { booking { id room { id name capacity } organiser { id name } attendees { id name } startTime endTime } errors } }",
  "variables": {
    "booking": {
      "roomId": "9fa8b122-9476-439f-ae5c-e97256444891",
      "organiserId": "4d4c933e-28c9-45ca-bf7c-a96f26cfa355",
      "attendeeIds": ["78514c8d-ac39-4a8a-9f97-abeb66eba37f"],
      "startTime": "2026-07-01T15:05:00",
      "endTime": "2026-07-01T15:10:00"
    }
  }
}

### Reset (deletes ALL stored rooms, people and bookings)
POST {{graphqlUrl}}
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "query": "mutation { reset }"
}


